<div class="form-frame">
  <h2>新規登録</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <p><%= f.label :email, "メールアドレス" %></p>
      <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
    </div>

    <div class="field">
      <p><%= f.label :nickname, "ニックネーム" %></p>
      <p><%= f.text_field :nickname, autofocus: true, autocomplete: "nickname" %></p>
    </div>

    <div class="field">
      <p><%= f.label :age, "年齢" %></p>
      <p><%= f.number_field :age, autofocus: true, autocomplete: "age" %></p>
    </div>

    <div class="field">
      <p><%= f.label :gender, "性別" %></p>
      <p><%= f.collection_select :gender_id, Gender.all, :id, :name %></p>
    </div>

    <div class="field">
      <p><%= f.label :password, "パスワード" %></p>
      <p><%= f.password_field :password, autocomplete: "new-password" %></p>
    </div>

    <div class="field">
      <p><%= f.label :password_confirmation, "パスワード再確認" %></p>
      <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
    </div>

    <div class="actions">
      <%= f.submit "登録" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
