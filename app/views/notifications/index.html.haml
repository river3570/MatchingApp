.notification 
  .notification__container 
    %h2.notification__title 通知一覧

    %ul.notification__lists 
      - @notifications.each do |notification|
        %li.notification__list
          = link_to user_path(notification.partner_id), class: "notification__list-link" do
            = ""
            %p.notification__context= notification.context
            %time.notification__date= notification.created_at.strftime('%Y年%m月%d日')
  
  = paginate @notifications